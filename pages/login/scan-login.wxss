.page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  box-sizing: border-box;
}

.panel {
  width: 100%;
  padding: 48rpx 36rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 16rpx 44rpx rgba(17, 24, 39, 0.08);
  box-sizing: border-box;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  text-align: center;
}

.subtitle {
  margin-top: 24rpx;
  font-size: 28rpx;
  line-height: 42rpx;
  color: #4b5563;
  text-align: center;
}

.session {
  margin-top: 28rpx;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #6b7280;
  font-size: 22rpx;
  word-break: break-all;
}

.retry-btn {
  margin-top: 36rpx;
  background: #111827;
  color: #ffffff;
  border-radius: 999rpx;
}
