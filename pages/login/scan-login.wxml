<view class="page">
  <view class="panel">
    <view class="title">Tovigor 设备登录</view>
    <view class="subtitle">{{statusText}}</view>
    <view class="session" wx:if="{{sessionId.length > 0}}">sessionId: {{sessionId}}</view>
    <button class="retry-btn" wx:if="{{showRetry}}" bindtap="confirmLogin">重试确认</button>
  </view>
</view>
